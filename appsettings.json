{
  "Mcp": {
    "Authority": "https://login.microsoftonline.com/{tenant-id}/v2.0",
    "Audience": "api://{client-id}",
    "Scopes": [
      {
        "ReadScope": "mymcp.read"
      },
      {
        "WriteScope": "mymcp.readwrite"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}